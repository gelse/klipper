# === Klipper / Moonraker / Fluidd Docker Configuration ===
# Copy this file to .env and adjust values for your setup

# User/group for file ownership matching the host
UID=1000
GID=1000

# Timezone
TZ=UTC

# Moonraker version to build (git tag or branch)
MOONRAKER_VERSION=master

# Fluidd version to build (git tag or branch)
FLUIDD_VERSION=v1.37.1

# Fluidd web UI port on the host
FLUIDD_PORT=80

# Paths on the host
CONFIG_PATH=./klipper_config
KLIPPER_LOG_PATH=./logs
MOONRAKER_LOG_PATH=./logs
MOONRAKER_DATA_PATH=./moonraker_data
GCODE_PATH=./gcode

# Serial device passed through from host
SERIAL_DEVICE=/dev/ttyUSB0

# Klipper API socket (internal, do not change unless you know what you're doing)
KLIPPER_API_SOCKET=/tmp/klippy_uds

# Shared socket directory between klipper and moonraker
SOCKETS_PATH=./sockets
